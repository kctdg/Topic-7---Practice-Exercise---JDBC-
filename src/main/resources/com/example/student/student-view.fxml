<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.student.StudentController"
      spacing="12"
      style="-fx-padding: 16; -fx-font-size: 13;">

    <Label text="Student Record Management System"
           style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="8">
        <Label text="Name:"         GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtName"  GridPane.rowIndex="0" GridPane.columnIndex="1"
                   promptText="Enter name" prefWidth="220"/>

        <Label text="Course:"         GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtCourse"  GridPane.rowIndex="1" GridPane.columnIndex="1"
                   promptText="Enter course" prefWidth="220"/>

        <Label text="Year Level:"  GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ChoiceBox fx:id="cbYear"  GridPane.rowIndex="2" GridPane.columnIndex="1"
                   prefWidth="220"/>
    </GridPane>

    <HBox spacing="8">
        <Button text="Add"    onAction="#addStudent"    prefWidth="90"/>
        <Button text="Update" onAction="#updateStudent" prefWidth="90"/>
        <Button text="Delete" onAction="#deleteStudent" prefWidth="90"/>
        <Button text="Clear"  onAction="#clearFields"   prefWidth="90"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"     text="ID"         prefWidth="60"/>
            <TableColumn fx:id="colName"   text="Name"       prefWidth="180"/>
            <TableColumn fx:id="colCourse" text="Course"     prefWidth="150"/>
            <TableColumn fx:id="colYear"   text="Year Level" prefWidth="120"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

</VBox>
